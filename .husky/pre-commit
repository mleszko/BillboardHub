#!/usr/bin/env sh
set -e

STAGED_FRONTEND_FILES="$(git diff --cached --name-only --diff-filter=ACMR | rg '\.(ts|tsx|js|jsx)$' || true)"
if [ -n "$STAGED_FRONTEND_FILES" ]; then
  echo "Running ESLint on staged frontend files..."
  npx eslint --max-warnings=0 --format json $STAGED_FRONTEND_FILES > /tmp/billboardhub-eslint-staged.json
fi

STAGED_PYTHON_FILES="$(git diff --cached --name-only --diff-filter=ACMR | rg '\.py$' || true)"
if [ -n "$STAGED_PYTHON_FILES" ]; then
  echo "Running Ruff on staged Python files..."
  PY=backend/.venv/bin/python
  if [ ! -x "$PY" ]; then
    PY=python3
  fi
  "$PY" -m ruff check $STAGED_PYTHON_FILES
fi

echo "Running backend pytest..."
PY=backend/.venv/bin/python
if [ ! -x "$PY" ]; then
  PY=python3
fi
"$PY" -m pytest -q backend/tests
