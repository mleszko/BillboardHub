APP_NAME=BillboardHub API
APP_ENV=development
APP_MODE_DEFAULT=auth
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# For local development; replace with Supabase Postgres URL in production.
DATABASE_URL=sqlite+aiosqlite:///./billboardhub.db

LLM_PRIMARY_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=mistral

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_IMPORT=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_HUBERT=claude-3-5-sonnet-latest

MISTRAL_API_KEY=
MISTRAL_MODEL_IMPORT=mistral-large-latest
MISTRAL_MODEL_HUBERT=mistral-large-latest

# Legacy OpenAI settings (optional, backward compatibility)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional for local dev. Required in production to verify Supabase JWT.
SUPABASE_JWT_SECRET=

# Import: set false to map columns with local heuristics only (no LLM / no row samples to providers).
IMPORT_USE_LLM=true
# Import: optional one-shot LLM patch for invalid rows during confirm step.
IMPORT_LLM_ROW_REPAIR=false

# Optional: absolute path to a local .xlsx for pytest test_golden_workbook_import (never commit the file).
# IMPORT_GOLDEN_WORKBOOK_PATH=
