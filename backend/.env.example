APP_NAME=BillboardHub API
APP_ENV=development
APP_MODE_DEFAULT=auth
ALLOWED_ORIGINS=http://localhost:3000

# For local development; replace with Supabase Postgres URL in production.
DATABASE_URL=sqlite+aiosqlite:///./billboardhub.db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional for local dev. Required in production to verify Supabase JWT.
SUPABASE_JWT_SECRET=
