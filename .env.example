# Vite app (repo root). Copy to .env for local dev.
VITE_BACKEND_URL=http://localhost:8000

# Optional: real auth via Supabase. If unset, the app uses dev user headers against the API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend: set SUPABASE_JWT_SECRET in backend/.env to the same JWT secret as your Supabase project
# (Settings → API → JWT Secret) so FastAPI can verify Bearer tokens.
